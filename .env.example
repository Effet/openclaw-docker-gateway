# Copy to .env and fill in as needed. All fields are optional.

# Container hostname (no dots allowed, e.g. o-m-v, my-nas)
# GATEWAY_HOSTNAME=openclaw-gateway

# ── Tailscale (only needed for: ./setup.sh tailscale) ─────────────────────────
# Recommended: OAuth client secret (never expires).
#   Create at: Tailscale admin → Settings → OAuth clients → devices:write scope
# Alternative: auth key (Settings → Keys) — remove after first registration.
# TS_AUTHKEY=tskey-client-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tag to advertise — must be defined in Tailscale ACL tagOwners.
# TS_TAG=tag:server

# ── npm ────────────────────────────────────────────────────────────────────────
# Registry mirror (e.g. for NAS or restricted networks)
# NPM_REGISTRY=https://registry.npmmirror.com

# Outbound proxy (single var, protocol required)
# Propagated to HTTPS_PROXY/HTTP_PROXY for npm; openclaw routed via proxychains4.
# PROXY=http://host:port
# PROXY=http://user:pass@host:port
# PROXY=socks5://host:port

# runtime dirs: ignored whole — Docker auto-creates bind-mount sources on `compose up`.
# Whole-dir ignore is robust against nested .git repos (e.g. sync.sh backup) appearing inside.
openclaw-config/
toolchain/
tailscale-state/
openclaw-workspace/
openclaw-workspaces/
openclaw-repos/

# Backups
backups/

# Logs
openclaw-logs/

# Secrets
.env

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp

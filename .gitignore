# runtime dirs: track only .gitkeep to preserve directory structure
openclaw-config/**
!openclaw-config/.gitkeep
toolchain/**
!toolchain/.gitkeep
tailscale-state/**
!tailscale-state/.gitkeep
# workspace is created by setup.sh / Docker; may itself be a git repo
openclaw-workspace/
openclaw-workspaces/

# Backups
backups/

# Secrets
.env

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
